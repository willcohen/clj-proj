------------------------------------------------------------
-- System-Wide Properties
------------------------------------------------------------
--
-- These describe cross-cutting properties of the library that do not scope
-- to a single contract or surface. Per-function dispatch properties are
-- specified as @invariant entries in GeneratedProjFunction above.
--
-- ResourceTracking: All PROJ objects (ProjObject, Context, CoordArray) are
--   automatically tracked for cleanup. JVM: via tech.v3.resource with :auto
--   tracking (GC-based). JS: via resource-tracker library with both automatic
--   GC tracking and explicit deterministic cleanup via releasing() blocks.
--   Users never need to call proj_destroy manually.
--
-- CrossWorkerReconciliation: JS only -- when ProjObject arguments to a
--   function live on different workers, they are transparently recreated on
--   the target worker via PROJJSON export and reimport, producing ISO-19111
--   compatible objects. A console.warn is emitted suggesting explicit contexts
--   for better performance.
--
-- PlatformDispatchConsistency: The same public API produces equivalent results
--   across all implementations (FFI, GraalVM, Node.js, Browser) for the same
--   inputs. Coordinate transformations produce identical numeric results within
--   floating-point tolerance.
--
-- ContextThreadSafety: JVM -- context operations are atomic via Clojure atom
--   swap!. JS -- contexts are pinned to specific workers; no cross-thread
--   access.
--
-- NetworkGridFetching: When network is enabled on a context, PROJ can fetch
--   transformation grids (NADCON, NTv2, etc.) from cdn.proj.org for
--   higher-accuracy results. This produces measurably different (more accurate)
--   transformation results compared to network-off.
--
-- SingleSourceFunctionDefinitions: All PROJ C API function signatures are
--   defined once in fndefs.cljc as data. Four systems read fndefs at
--   build time:
--     1. define-all-proj-public-fns macro (bb cherry) -- generates the
--        Clojure/JS wrapper functions for each entry
--     2. WASM link step (bb build --wasm) -- reads fndefs keys to build
--        the Emscripten EXPORTED_FUNCTIONS list. If a function isn't in
--        fndefs, the linker strips it from the .wasm binary.
--     3. FFI binding (JVM init) -- resolves native symbols at runtime
--     4. macros.cljs -- a derived copy of fndefs for CLJS macro expansion.
--        After editing fndefs.cljc, run `bb update-macro-fn-keys` to sync.
--   Adding a new PROJ function requires an entry in fndefs plus both
--   bb build --wasm (to export the symbol) and bb cherry (to generate
--   the wrapper). The dispatch system, argument extraction, and return
--   processing are automatic.
--
-- FfiToGraalFallback: On JVM, initialization always tries native FFI first.
--   If FFI fails (e.g. native library unavailable for the platform), the
--   library falls back to GraalVM WASM.
--
-- InternallyBundledArtifacts: The PROJ native libraries, WASM binary, proj.db,
--   and proj.ini are all internally bundled. There is no possibility of version
--   mismatch between components: they are built together from the same PROJ
--   source version.
--
-- GraalWasmNominalTyping: GraalVM's WASM engine uses nominal type checking for
--   indirect calls, unlike browser engines which use structural type checking.
--   Emscripten's addFunction creates mini wrapper modules with different type
--   indices, causing RuntimeError on indirect call in GraalVM. The library
--   works around this by compiling C callback stubs directly into the PROJ WASM
--   binary (proj_network_stubs.c). addFunction is never used on the GraalVM
--   path.

------------------------------------------------------------
-- Actor Declarations
------------------------------------------------------------

actor JavaApplication {}
actor ClojureApplication {}
actor JavaScriptApplication {}
actor ProjCLibrary {}

------------------------------------------------------------
-- Surfaces
------------------------------------------------------------

surface JavaApi {
    -- Java-friendly static wrapper (PROJ.java) over the Clojure API.
    -- Uses opaque Object handles for contexts, transformers, and coord arrays.
    -- All methods are static on the PROJ class. Lazily loads the Clojure
    -- namespace on first call.
    facing consumer: JavaApplication

    exposes:
        init() -> void
        forceGraal() -> void
        forceFfi() -> void
        toggleGraal() -> void
        isFfi() -> Boolean
        isGraal() -> Boolean
        isNode() -> Boolean
        contextCreate() -> Object
        contextPtr(context) -> Object
        contextDatabasePath(context) -> String
        isContext(obj) -> Boolean
        contextSetDatabasePath(context, path?) -> void
        coordArray(n, dims?) -> Object
        coordToCoordArray(coord) -> Object
        setCoords(coord_array, coords) -> void
        setCoord(coord_array, index, coord) -> void
        setCol(coord_array, col_index, values) -> void
        setXcol(coord_array, values) -> void
        setYcol(coord_array, values) -> void
        setZcol(coord_array, values) -> void
        setTcol(coord_array, values) -> void
        getCoords(coord_array, index) -> List<Decimal>
        errorCodeToString(error_code) -> String
        createCrsToCrs(context?, source_crs, target_crs) -> Any
        createCrsToCrsFromPj(context?, source_crs, target_crs) -> Any
        createFromDatabase(context?, auth_name, code) -> Any
        transArray(transformation, coord_array, n, direction?) -> Integer
        getAuthoritiesFromDatabase(context?) -> List<String>
        getCodesFromDatabase(context?, auth_name) -> List<String>
        getCrsInfoListFromDatabase(context, auth_name?) -> List<CrsInfoEntry>
        getUnitsFromDatabase(context, auth_name?, category?, allow_deprecated?) -> List<UnitInfoEntry>
        getCelestialBodyListFromDatabase(context, auth_name?) -> List<CelestialBodyInfoEntry>
        contextDestroy(context) -> void
        destroy(pj) -> void
        -- Explicit Java wrappers with Java-friendly signatures:
        getName(obj) -> String
        -- CRS Decomposition:
        getEllipsoid(context, obj) -> Any
        getPrimeMeridian(context, obj) -> Any
        crsGetCoordinateSystem(context, crs) -> Any
        csGetAxisCount(context, cs) -> Integer
        crsGetCoordoperation(context, crs) -> Any
        coordoperationGetParamCount(context, coordoperation) -> Integer
        coordoperationGetGridUsedCount(context, coordoperation) -> Integer
        -- Out-param functions (return typed maps with camelCase String keys):
        getAreaOfUse(context, obj) -> AreaOfUse?
        getAreaOfUseEx(context, obj, domainIdx) -> AreaOfUse?
        csGetAxisInfo(context, cs, index) -> AxisInfo?
        ellipsoidGetParameters(context, ellipsoid) -> EllipsoidParameters?
        primeMeridianGetParameters(context, pm) -> PrimeMeridianParameters?
        coordoperationGetMethodInfo(context, coordoperation) -> MethodInfo?
        coordoperationGetParam(context, coordoperation, index) -> CoordoperationParam?
        coordoperationGetGridUsed(context, coordoperation, index) -> GridUsedInfo?
        uomGetInfoFromDatabase(context, auth_name, code) -> UomInfo?
        gridGetInfoFromDatabase(context, grid_name) -> GridDatabaseInfo?
        coordoperationGetTowgs84Values(context, coordoperation, value_count, emit_error_if_incompatible) -> Map?
        -- TODO: remaining fndefs functions (getType, isDeprecated, asWkt,
        -- asProjString, asProjJson, getSourceCrs, getTargetCrs, etc.) are
        -- accessible through the Clojure API but do not yet have explicit
        -- Java static method wrappers in PROJ.java.

    @guarantee LazyNamespaceLoading
        -- The Clojure namespace is loaded on first API call, not at class load time.

    @guarantee CoordinatePadding
        -- setCoords and setCoord automatically pad input arrays to 4 dimensions
        -- (x, y, z, t) with zeros.

    @guarantee ColumnAccess
        -- setXcol/setYcol/setZcol/setTcol provide column-oriented coordinate
        -- writes for batch workflows.

    @guarantee KeywordConversion
        -- Struct-list functions (getCrsInfoListFromDatabase, getUnitsFromDatabase,
        -- getCelestialBodyListFromDatabase) convert Clojure keyword keys to
        -- Java String keys in the returned maps.

    @guarantee OutParamConversion
        -- Functions with C output parameters (out_*) allocate, read, and free
        -- heap memory automatically. Callers never handle pointers. The dispatch
        -- system returns typed maps matching the value types defined above:
        --   getAreaOfUse -> AreaOfUse (or null on failure)
        --   csGetAxisInfo -> AxisInfo (or null on failure)
        --   ellipsoidGetParameters -> EllipsoidParameters (or null on failure)
        --   primeMeridianGetParameters -> PrimeMeridianParameters (or null on failure)
        --   coordoperationGetMethodInfo -> MethodInfo (or null on failure)
        --   coordoperationGetParam -> CoordoperationParam (or null on failure)
        --   coordoperationGetGridUsed -> GridUsedInfo (or null on failure)
        --   uomGetInfoFromDatabase -> UomInfo (or null on failure)
        --   gridGetInfoFromDatabase -> GridDatabaseInfo (or null on failure)
        --   coordoperationGetTowgs84Values -> {:values [Decimal...]} (or null)
        -- Map key casing follows ReturnKeyNaming (see JavaScriptApi surface).
}

surface ClojureApi {
    -- The primary public API surface for JVM consumers (Clojure/Java).
    facing consumer: ClojureApplication

    exposes:
        init(log_level?, opts?) -> nil
        force_graal() -> nil
        force_ffi() -> nil
        context_create(opts?) -> Context
        coord_array(n, dims?) -> CoordArray
        set_coords(coord_array, coordinates) -> CoordArray
        get_coords(coord_array, index) -> Coordinate
        -- All fndefs-generated functions exposed as proj-{name} with
        -- automatic dispatch, argument extraction, and return processing.
        -- Examples:
        proj_create(opts) -> ProjObject
        proj_create_crs_to_crs(opts) -> ProjObject
        proj_create_from_database(opts) -> ProjObject
        proj_trans_array(opts) -> Integer
        proj_as_wkt(opts) -> String
        proj_get_authorities_from_database(opts?) -> List<String>
        proj_get_codes_from_database(opts) -> List<String>
        proj_get_crs_info_list_from_database(opts) -> List<CrsInfoEntry>
        proj_get_units_from_database(opts) -> List<UnitInfoEntry>
        proj_get_celestial_body_list_from_database(opts) -> List<CelestialBodyInfoEntry>

    @guarantee AutoInit
        -- Functions auto-initialize the library on first call.

    @guarantee ParameterFlexibility
        -- All opts maps accept both :underscore_keys and :hyphen-keys.
}

surface JavaScriptApi {
    -- The public API surface for JS consumers (Node.js and Browser).
    facing consumer: JavaScriptApplication

    exposes:
        -- All functions are exported in both camelCase (idiomatic JS) and
        -- snake_case (mirrors C API). Both are fully functional.
        init(opts?) -> Promise
        shutdown() -> Promise
        contextCreate(opts?) -> Promise<Context>
        coordArray(n) -> Promise<CoordArray>
        setCoords(coord_array, coordinates) -> Promise
        getCoords(coord_array, index) -> Promise<Coordinate>
        getWorkerMode() -> WorkerMode
        getWorkerCount() -> Integer
        -- All fndefs-generated functions exposed as camelCase (primary)
        -- with snake_case aliases. All return Promises.
        -- Examples:
        --   projCreateCrsToCrs(opts) (alias: proj_create_crs_to_crs)
        --   projTransArray(opts) (alias: proj_trans_array)
        -- Struct-list functions:
        projGetCrsInfoListFromDatabase(opts) -> Promise<Array<Object>>
        projGetUnitsFromDatabase(opts) -> Promise<Array<Object>>
        projGetCelestialBodyListFromDatabase(opts) -> Promise<Array<Object>>

    @guarantee ExplicitInit
        -- init() must be awaited before any other API call.

    @guarantee DualNaming
        -- Every function is exported in both camelCase and snake_case.
        -- camelCase is idiomatic for JavaScript consumers; snake_case
        -- mirrors the C API naming. Both are fully functional.

    @guarantee WorkerIsolation
        -- WASM execution happens in Web Workers, never on the main thread.

    @guarantee ReturnKeyNaming
        -- Returned map/object keys are idiomatic per platform:
        --   Clojure: kebab-case keywords (:west-lon-degree, :semi-major-metre)
        --   JavaScript: key casing determined by calling convention -- camelCase
        --     keys (westLonDegree) via camelCase alias, snake_case keys
        --     (west_lon_degree) via snake_case alias.
        --   Java: camelCase String keys ("westLonDegree", "semiMajorMetre")
        -- Applies to both struct-list and out-param results.
}

surface NetworkCallbackInterface {
    -- The boundary between clj-proj and PROJ's C network callback API.
    -- Four callbacks implement HTTP range request fetching from cdn.proj.org.
    facing proj_library: ProjCLibrary

    exposes:
        open(url, offset, size_to_read) -> handle
        close(handle) -> nil
        get_header(handle, header_name) -> String
        read_range(handle, offset, size_to_read, buffer) -> Integer

    @guarantee HttpRangeRequests
        -- All network operations use HTTP Range requests for efficient
        -- partial grid file downloads.
}

------------------------------------------------------------
-- Lifecycle Functions (called automatically by resource tracking)
------------------------------------------------------------

-- These functions are not modeled as rules because they are never called
-- directly by users. The resource tracking system (tech.v3.resource on JVM,
-- resource-tracker on JS) calls them automatically during cleanup.
--
--   proj_context_create, proj_context_destroy,
--   proj_destroy, proj_list_destroy,
--   proj_string_list_destroy, proj_celestial_body_list_destroy,
--   proj_crs_info_list_destroy, proj_unit_list_destroy,
--   proj_get_crs_list_parameters_create, proj_get_crs_list_parameters_destroy,
--   proj_insert_object_session_destroy,
--   proj_operation_factory_context_destroy,
--   proj_int_list_destroy, proj_string_destroy

------------------------------------------------------------
-- Open Questions
------------------------------------------------------------

-- (No open questions at this time.)

------------------------------------------------------------
-- Resolved Design Decisions
------------------------------------------------------------

-- 1. GraalVM addFunction: RESOLVED. GraalVM's nominal type checking breaks
--    Emscripten addFunction. Fixed architecturally with C stubs compiled into
--    the WASM binary (proj_network_stubs.c). addFunction is never called on
--    GraalVM. See invariant GraalWasmNominalTyping.
--
-- 2. Version mismatches: NOT APPLICABLE. All artifacts (native libs, WASM,
--    proj.db) are internally bundled and built from the same PROJ source.
--    See invariant InternallyBundledArtifacts.
--
-- 3. JS resource cleanup: SUPPORTED. Both automatic GC-based tracking and
--    explicit deterministic cleanup via resource-tracker's releasing() blocks.
--    See invariant ResourceTracking.
--
-- 4. Platform degradation: RESOLVED. FFI -> GraalVM fallback is the definitive
--    strategy. If native FFI is unavailable, the library always degrades to
--    GraalVM WASM. See invariant FfiToGraalFallback.
--
-- 5. Struct-aware return types: RESOLVED. Functions returning C struct arrays
--    use :proj-returns :struct-list with :struct-def, :struct-fields, and
--    :struct-destroy-fn metadata in fndefs. FFI reads fields via dtype-next's
--    struct system (ffi-clang/defstruct-from-layout in struct.clj). WASM reads
--    at explicit 32-bit offsets from :struct-fields. The hand-written
--    get-crs-info-list-from-database wrapper is replaced by the generated
--    proj-get-crs-info-list-from-database. See invariant StructAwareReturnType.
--
-- 6. Naming inconsistency: RESOLVED. get-crs-info-list-from-database renamed
--    to proj-get-crs-info-list-from-database (Clojure) /
--    projGetCrsInfoListFromDatabase (JS) to match the convention. Old name
--    removed entirely (still in alpha, no backwards compatibility needed).
