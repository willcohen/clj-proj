rule CrsGetCoordoperation {
    -- Extract the map projection conversion from a projected CRS.
    -- This is the key entry point for getting a serializable projection
    -- definition from a projected CRS: the resulting conversion PJ can be
    -- passed to AsProjString/AsProjjson/AsWkt (unlike the concatenated
    -- operation from CreateCrsToCrs).
    when: CrsGetCoordoperation(crs, ctx?)
    requires: crs.type = projected_crs
    ensures: result != null

    @guidance
        -- @test CLJ[x] JS[x] PW[x] Java[x]
        -- EPSG:2249 -> conversion with method "Lambert Conic Conformal (2SP)"
        -- Result is serializable: AsProjString yields "+proj=lcc ..."
}

