rule GetEllipsoid {
    -- Extract the ellipsoid from a CRS or GeodeticReferenceFrame.
    -- Fails with "Object is not a CRS or GeodeticReferenceFrame" for other
    -- PJ types (e.g. concatenated operations from CreateCrsToCrs).
    when: GetEllipsoid(obj, context?)
    requires: obj != null
    ensures:
        if obj.is_crs or obj.type in {geodetic_reference_frame, dynamic_geodetic_reference_frame}:
            result != null
        else:
            result = null

    @guidance
        -- @test CLJ[x] JS[x] PW[x] Java[x]
        -- EPSG:4326 -> ellipsoid named "WGS 84"
        -- EPSG:2249 (projected CRS) -> ellipsoid (traverses to geodetic CRS)
        -- concatenated_operation PJ -> null (not a CRS)
}

