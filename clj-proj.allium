-- allium: 3
-- clj-proj.allium

-- Scope: Cross-platform PROJ bindings library (JVM + JavaScript)
-- Includes: Initialization, context management, CRS operations, coordinate
--           transformation, database queries, resource lifecycle, network grid
--           fetching, worker pool management
-- Excludes:
--   - Build system (Nix, Babashka, Emscripten compilation)
--   - Native library packaging / cross-compilation
--   - PROJ C internals (PROJ is an external dependency)
--   - Cherry/esbuild transpilation pipeline
--   - CI/CD configuration

------------------------------------------------------------
-- Value Types
------------------------------------------------------------

value Coordinate {
    x: Decimal
    y: Decimal
    z: Decimal?
    t: Decimal?
}

value AreaOfUse {
    west_lon_degree: Decimal
    south_lat_degree: Decimal
    east_lon_degree: Decimal
    north_lat_degree: Decimal
    area_name: String?
}

value AxisInfo {
    name: String
    abbreviation: String
    direction: String
    unit_conv_factor: Decimal
    unit_name: String
    unit_auth_name: String
    unit_code: String
}

value EllipsoidParameters {
    semi_major_metre: Decimal
    semi_minor_metre: Decimal
    is_semi_minor_computed: Integer
    inv_flattening: Decimal
}

value PrimeMeridianParameters {
    longitude: Decimal
    unit_conv_factor: Decimal
    unit_name: String
}

value MethodInfo {
    method_name: String
    method_auth_name: String
    method_code: String
}

value CoordoperationParam {
    name: String
    auth_name: String
    code: String
    value: Decimal
    value_string: String
    unit_conv_factor: Decimal
    unit_name: String
    unit_auth_name: String
    unit_code: String
    unit_category: String
}

value GridUsedInfo {
    short_name: String
    full_name: String
    package_name: String
    url: String
    direct_download: Integer
    open_license: Integer
    available: Integer
}

value UomInfo {
    name: String
    conv_factor: Decimal
    category: String
}

value GridDatabaseInfo {
    full_name: String
    package_name: String
    url: String
    direct_download: Integer
    open_license: Integer
    available: Integer
}

value CrsInfoEntry {
    auth_name: String
    code: String
    name: String
    type: PjType
    deprecated: Boolean
    bbox_valid: Boolean
    west_lon_degree: Decimal
    south_lat_degree: Decimal
    east_lon_degree: Decimal
    north_lat_degree: Decimal
    area_name: String
    projection_method_name: String?
    celestial_body_name: String?
}

value UnitInfoEntry {
    auth_name: String
    code: String
    name: String
    category: String
    conv_factor: Decimal
    proj_short_name: String?
    deprecated: Boolean
}

value CelestialBodyInfoEntry {
    auth_name: String
    name: String
}

------------------------------------------------------------
-- Contracts
------------------------------------------------------------

contract GeneratedProjFunction {
    -- The shared behavioral contract obeyed by every function generated from
    -- fndefs.cljc. ~100 PROJ C API functions are generated via macros from a
    -- single data definition. Each generated function follows this contract.

    dispatch: (fn_key: String, fn_def: Any, opts: Any) -> Any

    @invariant AutoInit
        -- Calls ensure_initialized! before dispatch. On JVM, this triggers
        -- library initialization on first use. On JS, warns if not initialized.

    @invariant ContextResolution
        -- If the function requires a context argument:
        --   1. Use the provided context if given
        --   2. Else inherit context from any ProjObject argument
        --   3. Else auto-create a fresh context
        -- Context accepts both :ctx and :context parameter names.

    @invariant ArgumentExtraction
        -- Arguments are extracted from an opts map using the function's
        -- :argtypes definition. Both underscore and hyphenated key names
        -- are accepted. Defaults from :argsemantics are applied for missing
        -- optional arguments.
        --
        -- Nullable argument handling:
        --   :pointer? - dtype-next nullable pointer type. Accepts nil/0 without
        --     throwing "Pointer value is zero!" (unlike :pointer which rejects
        --     null pointers). Used for C API parameters where NULL is valid
        --     (e.g. out_warnings, options, area).
        --   :pointer with nil value - extract-args converts nil to 0 (null
        --     pointer) for all platforms.
        --   :string with nil value - platform-divergent handling because PROJ's
        --     C API treats NULL and "" differently on WASM:
        --       FFI: nil becomes "" (dtype-next's string->c rejects nil)
        --       GraalVM: nil becomes 0 (NULL, Emscripten treats as "all/any")
        --       CLJS: nil becomes 0 (NULL, same as GraalVM)
        --     On FFI, PROJ treats "" the same as NULL for most parameters.
        --     On WASM (Emscripten), "" is a valid allocated C string that
        --     PROJ matches literally -- it does NOT mean "all". NULL (0) is
        --     required for "all/any" semantics on WASM.
        --     Callers should omit optional string args (let them default to nil)
        --     rather than passing "". The dispatch layer handles the rest.

    @invariant PlatformDispatch
        -- The call is routed to the active implementation:
        --   FFI: resolved via ns-resolve to native.clj function
        --   GraalVM: routed through wasm.cljc ccall
        --   CLJS: posted to the appropriate worker via worker-call

    @invariant ReturnProcessing
        -- Return values are processed based on :proj-returns metadata:
        --   :pj -> tracked for auto-destroy via proj_destroy
        --   :pj-list -> tracked for auto-destroy via proj_list_destroy
        --   :string-list -> dereferenced to vector of strings, C memory freed
        --   :struct-list -> parsed to vector of maps using :struct-fields metadata
        --     (see StructAwareReturnType below)
        --   :out-params -> allocates out-pointers, calls C function, reads back
        --     typed fields, frees allocations (see OutParamDispatch below)
        --   :pj-context -> tracked for auto-destroy via proj_context_destroy
        --   :pj-insert-session -> tracked, type-specific destroy
        --   :pj-operation-factory-context -> tracked, type-specific destroy
        --   (no metadata) -> returned as-is
        -- Null/zero pointers produce nil; no exception is thrown.

    @invariant StructAwareReturnType
        -- Functions returning C struct arrays use :proj-returns :struct-list
        -- with additional metadata in fndefs:
        --   :struct-def - keyword referencing a dtype-next struct definition
        --     registered via ffi-clang/defstruct-from-layout in struct.clj
        --     (e.g. :proj-crs-info, :proj-unit-info, :proj-celestial-body-info)
        --   :struct-fields - vector of [keyword type wasm-offset] for
        --     WASM-side parsing where type is :string, :int, :double, or :boolean.
        --     FFI reads fields by name from the dtype-next struct definition.
        --   :struct-destroy-fn - C function name to destroy the result list
        --   :struct-params-create - optional C function to create params object
        --   :struct-params-destroy - optional C function to destroy params object
        --   :count-arg-name - name of the out_result_count parameter
        --
        -- Platform-specific struct reading:
        --   FFI: Uses dtype-next's struct system (tech.v3.datatype.struct)
        --     with LLVM record layout strings parsed by ffi-clang. The struct
        --     definitions in struct.clj handle alignment and field access by
        --     name, eliminating hardcoded byte offsets.
        --   GraalVM/CLJS: Uses :struct-fields wasm-offsets (32-bit pointers,
        --     4-byte ints, 8-byte doubles) to read from WASM linear memory.
        --
        -- The dispatch system:
        --   1. Allocates count output pointer (4 bytes, platform-specific)
        --   2. Optionally creates params object via :struct-params-create
        --   3. Calls the C function
        --   4. Reads count from count pointer
        --   5. Iterates count-many structs, reading typed fields per platform
        --   6. Destroys the result list via :struct-destroy-fn
        --   7. Optionally destroys the params object
        --   8. Frees the count pointer
        --   9. Returns a vector of maps with keyword keys
        --
        -- Three functions use this system:
        --   proj_get_crs_info_list_from_database -> List<CrsInfoEntry>
        --   proj_get_units_from_database -> List<UnitInfoEntry>
        --   proj_get_celestial_body_list_from_database -> List<CelestialBodyInfoEntry>
        --
        -- Nil string args in struct-list functions follow the same nullable
        -- argument handling described in ArgumentExtraction above.

    @invariant OutParamDispatch
        -- Functions returning data through C output parameters (out_*) use
        -- :proj-returns :out-params with additional metadata in fndefs:
        --   :out-fields - vector of [keyword type] pairs describing output
        --     parameters. Types: :double, :string, :int, :double-array.
        --   :argtypes retains the full C signature including out_* pointer
        --     args (required for FFI binding generation via dtype-next and
        --     WASM ccall arg-type lists). The dispatch system identifies
        --     output args by the out_ prefix on the arg name and filters
        --     them from extract-args so callers never provide them.
        --
        -- For :double-array, the field spec includes :count-arg referencing
        -- a real argument (as keyword) that supplies the array length:
        --   [:values :double-array :count-arg :value_count]
        --
        -- Platform-specific allocation and reading:
        --   FFI: JNA Memory objects (pointer-size 8 on 64-bit native).
        --     getDouble(0), getInt(0), getPointer(0).getString(0, "UTF-8").
        --   GraalVM: _malloc / getValue / UTF8ToString / _free on WASM heap
        --     (pointer-size 4, 32-bit WASM address space).
        --   CLJS: Worker handles malloc/read/free internally (like struct-list).
        --     outFields metadata is passed in the ccall command; the worker
        --     allocates, appends to args/argTypes, reads results, and frees.
        --
        -- The dispatch system:
        --   1. Builds input-fn-def with out_ args filtered from argtypes
        --   2. Extracts non-out args via extract-args using input-fn-def
        --   3. Allocates heap space for each :out-fields entry
        --   4. Builds full C arg list: input args interleaved with out-pointers
        --      at their original positions in :argtypes
        --   5. Calls the C function with the full arg list
        --   6. If return is 0 (failure): frees all allocations, returns nil
        --   7. If return is nonzero: reads each field by type into a map
        --   8. Frees all allocations
        --   9. Returns map with keyword keys matching :out-fields names
        --
        -- Ten functions use scalar out-params:
        --   proj_get_area_of_use -> AreaOfUse
        --   proj_get_area_of_use_ex -> AreaOfUse
        --   proj_cs_get_axis_info -> AxisInfo
        --   proj_ellipsoid_get_parameters -> EllipsoidParameters
        --   proj_prime_meridian_get_parameters -> PrimeMeridianParameters
        --   proj_coordoperation_get_method_info -> MethodInfo
        --   proj_coordoperation_get_param -> CoordoperationParam
        --   proj_coordoperation_get_grid_used -> GridUsedInfo
        --   proj_uom_get_info_from_database -> UomInfo
        --   proj_grid_get_info_from_database -> GridDatabaseInfo
        --
        -- One function uses :double-array out-param:
        --   proj_coordoperation_get_towgs84_values -> {:values [Decimal...]}

    @invariant ContextAttachment
        -- ProjObject results have the originating context attached, so
        -- subsequent calls can inherit it for worker affinity (JS) and
        -- thread safety (JVM).

    @guidance
        -- The full catalog of generated functions is defined in
        -- src/cljc/net/willcohen/proj/fndefs.cljc as the fndefs-raw map.
        -- Each function is individually specified as a rule in this spec.
}

------------------------------------------------------------
-- Enumerations
------------------------------------------------------------

enum Implementation { ffi | graal | node | browser | unknown }

enum PjDirection { forward | identity | inverse }

enum PjType {
    unknown | ellipsoid | prime_meridian
    | geodetic_reference_frame | dynamic_geodetic_reference_frame
    | vertical_reference_frame | dynamic_vertical_reference_frame
    | datum_ensemble
    | crs | geodetic_crs | geocentric_crs
    | geographic_crs | geographic_2d_crs | geographic_3d_crs
    | vertical_crs | projected_crs | compound_crs
    | temporal_crs | engineering_crs | bound_crs | other_crs
    | conversion | transformation
    | concatenated_operation | other_coordinate_operation
    | temporal_datum | engineering_datum | parametric_datum
    | derived_projected_crs | coordinate_metadata
}

enum WktType {
    wkt2_2015 | wkt2_2015_simplified
    | wkt2_2019 | wkt2_2019_simplified
    | wkt1_gdal | wkt1_esri
}

enum WorkerMode { pthreads | single_threaded }

------------------------------------------------------------
-- Entities and Variants
------------------------------------------------------------

entity Library {
    -- The singleton library instance managing global state.
    implementation: Implementation?
    force_graal: Boolean

    -- Derived
    is_initialized: implementation != null
}

entity Context {
    -- A PROJ threading context. Wraps a native pointer with operation tracking.
    -- JVM: atom holding {:ptr, :op, :result}
    -- JS: plain object with ptr, ctx_id, worker_idx
    pointer: Integer
    operation_count: Integer
    network_enabled: Boolean
    database_path: String?
    worker_idx: Integer?
}

entity ProjObject {
    -- An opaque handle to a PROJ object (CRS, transformation, coordinate
    -- system, datum, ellipsoid, etc.). Platform representation varies:
    -- FFI: tech.v3.datatype.ffi.Pointer
    -- GraalVM: org.graalvm.polyglot.Value
    -- CLJS: integer (Emscripten pointer)
    context: Context?

    -- Derived from PROJ queries
    name: String?
    type: PjType?
    is_deprecated: Boolean?
    is_crs: Boolean?
}

entity CoordArray {
    -- A buffer of 4D coordinates (x, y, z, t) for batch transformation.
    -- FFI: dtype-next tensor
    -- GraalVM: WASM heap allocation
    -- CLJS: JS-side Float64Array (transferred to worker on demand)
    num_coords: Integer
    dimensions: Integer
}

entity WorkerPool {
    -- JS-only: pool of Web Workers running the WASM module.
    mode: WorkerMode
    worker_count: Integer
}

entity OperationFactoryContext {
    -- Controls how PROJ searches for coordinate operations.
    authority: String?
    desired_accuracy: Decimal?
    area_of_interest: AreaOfUse?
    grid_availability_use: Integer?
    allow_ballpark: Boolean?
    discard_superseded: Boolean?
}

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
    default_wkt_type: WktType = wkt2_2019
    -- Network CDN URL (https://cdn.proj.org) is managed by PROJ's C library
    -- internally, not configurable from the Clojure/JS layer.
}

------------------------------------------------------------
-- Rules
------------------------------------------------------------
--
-- Rule naming convention: rules use short, readable PascalCase names that
-- may abbreviate the C API name. The mapping to fndefs keys is:
--   Rule name         fndefs key (C API)
--   CreateContext      proj_context_create
--   SetDatabasePath    proj_context_set_database_path
--   EnableNetwork      proj_context_set_enable_network
--   TransformArray     proj_trans_array
--   GetAuthorities     proj_get_authorities_from_database
--   GetCodes           proj_get_codes_from_database
--   GetCrsInfoList     proj_get_crs_info_list_from_database
--   GetCelestialBodyList  proj_get_celestial_body_list_from_database
--   GetCoordinateSystem   proj_crs_get_coordinate_system
--   GetGeodeticCrs     proj_crs_get_geodetic_crs
--   GetDatum           proj_crs_get_datum
--   GetAxisCount       proj_cs_get_axis_count
--   GetAxisInfo        proj_cs_get_axis_info
--   AsProjJson         proj_as_projjson
--   PromoteTo3D        proj_crs_promote_to_3d
--   DemoteTo2D         proj_crs_demote_to_2d
-- All other rules map by mechanical PascalCase conversion (e.g.
-- GetEllipsoid -> proj_get_ellipsoid).
--
-- Internal destroy/lifecycle functions in fndefs have no corresponding rules.
-- They are managed by the ResourceTracking system-wide property:
--   proj_destroy, proj_context_destroy, proj_list_destroy,
--   proj_string_destroy, proj_crs_info_list_destroy,
--   proj_unit_list_destroy, proj_celestial_body_list_destroy,
--   proj_insert_object_session_destroy, proj_operation_factory_context_destroy,
--   proj_int_list_destroy, proj_get_crs_list_parameters_create,
--   proj_get_crs_list_parameters_destroy
--
-- Non-fndefs rules (manually implemented, not generated from C API):
--   Initialize, ForceGraal, ForceFfi, ToggleGraal, Shutdown,
--   QueryImplementation, CoordToCoordArray, SetCoord, SetColumn,
--   AllocateCoordArray, SetCoords, GetCoords

-- Initialization Flow

rule Initialize {
    -- Initialize the PROJ library, selecting the best available backend.
    -- JVM: tries FFI first, falls back to GraalVM WASM.
    -- JS: initializes worker pool, returns a Promise.
    when: Initialize(log_level?, opts?)

    requires: Library.implementation = null

    ensures:
        if Platform = jvm:
            if Library.force_graal = false:
                -- Try native FFI first
                if NativeAvailable:
                    Library.implementation = ffi
                else:
                    Library.implementation = graal
            else:
                Library.implementation = graal
        if Platform = js:
            WorkerPool.created(mode: detected_mode, worker_count: detected_count)
            Library.implementation = detected_runtime

    @guidance
        -- @test CLJ[x] JS[x] PW[x] Java[x]
        -- after init, implementation is non-nil
}

rule ForceGraal {
    -- Force GraalVM implementation on next initialization (JVM only).
    when: ForceGraal()
    ensures:
        Library.force_graal = true
        Library.implementation = null

    @guidance
        -- @test CLJ[x] JS[-] PW[-] Java[x]
        -- after force-graal!, next init uses GraalVM
}

rule ForceFfi {
    -- Force native FFI implementation on next initialization (JVM only).
    when: ForceFfi()
    ensures:
        Library.force_graal = false
        Library.implementation = null

    @guidance
        -- @test CLJ[x] JS[-] PW[-] Java[x]
        -- after force-ffi!, next init uses native FFI
}

rule ToggleGraal {
    -- Toggle the force_graal flag (JVM only). Resets implementation to null,
    -- triggering re-initialization on next API call.
    when: ToggleGraal()
    ensures:
        Library.force_graal = not Library.force_graal
        Library.implementation = null

    @guidance
        -- @test CLJ[ ] JS[-] PW[-] Java[ ]
        -- toggles force_graal state
}

rule Shutdown {
    -- JS only: terminate all workers so the process can exit.
    when: Shutdown()
    ensures: WorkerPool.worker_count = 0

    @guidance
        -- @test CLJ[-] JS[x] PW[-] Java[ ]
        -- after shutdown(), process exits cleanly
}

-- Implementation Query Flow

rule QueryImplementation {
    -- Check which backend is active. ffi?, graal?, node? are public predicates.
    when: QueryImplementation()
    ensures: Library.implementation != null

    @guidance
        -- @test CLJ[x] JS[-] PW[-] Java[x]
        -- (ffi?) or (graal?) returns true
}

-- Coordinate Helper Flow

rule CoordToCoordArray {
    -- Convert a single coordinate (vector or tensor) into a fresh 1-element
    -- CoordArray. Cross-platform (JVM + JS). Auto-initializes the library
    -- if not yet initialized.
    when: CoordToCoordArray(coord)

    requires: Library.is_initialized = true

    ensures: CoordArray.created(num_coords: 1)

    @guidance
        -- @test CLJ[x] JS[x] PW[x] Java[x]
        -- [42.36, -71.06, 100.0, 0.0] -> 1-element array, roundtrips within 0.0001
}

rule SetCoord {
    -- JVM only: set a single coordinate at a given index in a coord array.
    -- Writes coord into coord_array at the given index.
    when: SetCoord(coord_array, index, coord)
    requires: coord_array != null
    requires: index >= 0
    requires: index < coord_array.num_coords
    ensures: coord_array.num_coords > 0

    @guidance
        -- @test CLJ[x] JS[-] PW[-] Java[ ]
        -- set-coord!(ca, 1, [10 20 30 40]) -> get-coords(ca, 1) roundtrips
}

rule SetColumn {
    -- JVM only: set all values for a specific coordinate dimension at once.
    -- set-col!(ca, 0, xs) sets all X values; set-xcol!/set-ycol!/set-zcol!/
    -- set-tcol! are convenience wrappers for columns 0/1/2/3.
    when: SetColumn(coord_array, column_index, values)
    requires: coord_array != null
    requires: column_index >= 0
    requires: column_index <= 3
    ensures: coord_array.num_coords > 0

    @guidance
        -- @test CLJ[x] JS[-] PW[-] Java[ ]
        -- set-xcol!/set-ycol! -> per-column values roundtrip via get-coords
}

-- Context Management Flow

rule CreateContext {
    -- Create a new PROJ context with database path and optional network.
    when: CreateContext(opts?)

    requires: Library.is_initialized = true

    ensures: Context.created(
        network_enabled: opts.network ?? true,
        database_path: resolved_db_path
    )

    ensures:
        if Library.implementation = ffi:
            -- Logging callback registered via JNA
            -- Network callbacks registered via proj_context_set_network_callbacks
            LoggingConfigured(context)
            if opts.network ?? true:
                NetworkCallbacksRegistered(context)

        if Library.implementation = graal:
            -- Network callbacks registered via C stubs before network enabled
            if opts.network ?? true:
                NetworkCallbacksRegistered(context)

        -- JS: worker handles context setup internally

    @guidance
        -- @test CLJ[x] JS[x] PW[x] Java[x]
        -- context-create -> non-nil context with :ptr key
}

rule SetDatabasePath {
    -- Set the path to proj.db on a context.
    when: SetDatabasePath(context, db_path?)

    ensures:
        context.database_path = db_path ?? default_for_platform

    @guidance
        -- @test CLJ[ ] JS[ ] PW[ ] Java[ ]
        -- context + path -> does not throw
}

rule EnableNetwork {
    -- Enable or disable network grid fetching on a context.
    when: EnableNetwork(context, enabled)

    ensures: context.network_enabled = enabled

    @guidance
        -- @test CLJ[x] JS[x] PW[ ] Java[ ]
        -- context + enabled=1 -> is_network_enabled returns 1
}

-- CRS and Object Creation Flow

rule CreateCrsToCrs {
    -- Create a coordinate transformation between two CRS specified by code.
    -- Context is optional: if not provided, one is auto-created.
    -- The resulting PJ may be a concatenated_operation internally (e.g. when
    -- a datum shift is required between source and target). Concatenated
    -- operations work for transformation (projTransArray) but cannot be
    -- serialized via AsProjString/AsProjjson/AsWkt. To extract a serializable
    -- projection definition, use GetTargetCrs -> CrsGetCoordoperation on the
    -- target CRS instead.
    when: CreateCrsToCrs(source_crs, target_crs, context?, area?)

    ensures: ProjObject.created(context: context ?? auto_created_context)

    @guidance
        -- @test CLJ[x] JS[x] PW[x] Java[x]
        -- "EPSG:4326" + "EPSG:2249" -> non-nil transformer
        --
        -- source_crs and target_crs are authority:code strings (e.g. "EPSG:4326").
        -- Parameters accept both underscore and hyphen naming conventions.
        -- Result type varies: simple reprojections (e.g. 4326->3857) produce
        -- a directly exportable operation; datum-shifting pairs (e.g. 4326->2249)
        -- produce a concatenated_operation.
}

rule CreateCrsToCrsFromPj {
    -- Create a coordinate transformation between two ProjObject CRS instances.
    when: CreateCrsToCrsFromPj(source_crs, target_crs, context?, area?, options?)

    requires: source_crs != null
    requires: target_crs != null

    ensures: ProjObject.created(context: context ?? auto_created_context)

    @guidance
        -- @test CLJ[x] JS[x] PW[x] Java[x]
        -- EPSG:4326 PJ + EPSG:2249 PJ -> non-nil transformer
        --
        -- In JS with workers, if source_crs and target_crs live on different
        -- workers, the library transparently reconciles them by recreating
        -- mismatched objects on the target worker via PROJJSON roundtrip.
        -- A console.warn is emitted when this happens.
}

rule CreateFromDatabase {
    -- Look up a PROJ object by authority, code, and category.
    when: CreateFromDatabase(auth_name, code, context?, category?, use_proj_alternative_grid_names?, options?)

    ensures: ProjObject.created(context: context ?? auto_created_context)

    @guidance
        -- @test CLJ[x] JS[x] PW[x] Java[x]
        -- "EPSG" + "4326" -> non-nil CRS object
}

rule Create {
    -- Create a PROJ object from any definition string: PROJ string, WKT,
    -- or pipeline definition. This is the low-level entry point that
    -- enables raw pipeline strings like "+proj=pipeline +step +proj=robin".
    when: Create(definition, context?)

    ensures: ProjObject.created(context: context ?? auto_created_context)

    @guidance
        -- @test CLJ[x] JS[x] PW[x] Java[x]
        -- "+proj=robin" -> non-nil ProjObject
        -- "+proj=pipeline +step +proj=utm +zone=32" -> non-nil ProjObject
        -- "EPSG:4326" -> non-nil CRS (shorthand for create_from_database)
}

rule CreateFromWkt {
    -- Create a PROJ object from a WKT string.
    when: CreateFromWkt(wkt, context?, options?)

    ensures: ProjObject.created(context: context ?? auto_created_context)

    @guidance
        -- @test CLJ[x] JS[x] PW[x] Java[ ]
        -- WKT of EPSG:4326 -> CRS with name "WGS 84"
}

-- Coordinate Transformation Flow

rule AllocateCoordArray {
    -- Create a coordinate buffer for n coordinates.
    when: AllocateCoordArray(n, dims?)

    requires: Library.is_initialized = true

    ensures: CoordArray.created(
        num_coords: n,
        dimensions: dims ?? 4
    )

    @guidance
        -- @test CLJ[x] JS[x] PW[x] Java[x]
        -- coord-array(1) -> non-nil array
        --
        -- FFI: allocates dtype-next tensor on native heap with auto resource tracking.
        -- GraalVM: allocates on WASM heap.
        -- JS: creates JS-side Float64Array; data transferred to worker on demand.
}

rule SetCoords {
    -- Write coordinate values into a CoordArray.
    when: SetCoords(coord_array, coordinates)

    requires: coord_array != null

    ensures: coord_array.num_coords > 0

    @guidance
        -- @test CLJ[x] JS[x] PW[x] Java[x]
        -- set-coords!(ca, [[42.36, -71.06, 0, 0]]) -> does not throw
}

rule GetCoords {
    -- Read coordinate values from a CoordArray at an index.
    when: GetCoords(coord_array, index)

    requires: coord_array != null
    requires: index >= 0
    requires: index < coord_array.num_coords

    ensures: result != null

    @guidance
        -- @test CLJ[x] JS[x] PW[x] Java[x]
        -- get-coords(ca, 0) -> [x, y, z, t] matching set values
}

rule TransformArray {
    -- Batch-transform coordinates in place.
    when: TransformArray(p, direction: PjDirection, n, coord)

    requires: p != null
    requires: coord != null
    requires: n <= coord.num_coords

    ensures: coord.num_coords > 0

    @guidance
        -- @test CLJ[x] JS[x] PW[x] Java[x]
        -- 4326->2249 + Boston [42.36, -71.06] -> ~[775200, 2956400] feet
        --
        -- Coordinates are transformed in-place.
        -- FFI: direct native memory access.
        -- GraalVM: WASM memory operations.
        -- JS: data is transferred to the correct worker, transformed, and
        --     results written back to the JS-side Float64Array.
}

-- Database Query Flow

rule GetAuthorities {
    -- List all authority names in the PROJ database.
    when: GetAuthorities(context?)

    ensures: result != null

    @guidance
        -- @test CLJ[x] JS[x] PW[x] Java[x]
        -- -> non-empty list containing "EPSG"
}

rule GetCodes {
    -- List all codes for a given authority and type.
    when: GetCodes(auth_name, context?, type?, allow_deprecated?)

    ensures: result != null

    @guidance
        -- @test CLJ[x] JS[x] PW[x] Java[x]
        -- "EPSG" -> list containing "4326"
}

rule GetCrsInfoList {
    -- Return detailed CRS information from the database.
    -- Uses the struct-aware return type system (StructAwareReturnType invariant).
    -- FFI reads fields via dtype-next struct definition :proj-crs-info.
    -- WASM reads fields at 32-bit offsets from :struct-fields metadata.
    when: GetCrsInfoList(context?, auth_name?)

    ensures: result != null

    @guidance
        -- @test CLJ[x] JS[x] PW[x] Java[x]
        -- "EPSG" -> >1000 entries, includes 4326 "WGS 84"
        --
        -- EPSG alone has >1000 entries.
        -- Omitting auth_name returns entries from all authorities.
        -- CRS info list requires a params object (proj_get_crs_list_parameters_create/destroy).
        -- The params object is optional in the metadata and auto-created/destroyed.
}

rule GetUnitsFromDatabase {
    -- Return unit information from the database.
    -- Uses the struct-aware return type system (StructAwareReturnType invariant).
    when: GetUnitsFromDatabase(context?, auth_name?, category?, allow_deprecated?)

    ensures: result != null

    @guidance
        -- @test CLJ[x] JS[x] PW[x] Java[x]
        -- "EPSG" + "linear" -> includes 9001 (metre), 9003 (US survey foot)
        --
        -- category filters by unit type (e.g. "linear", "angular").
        -- Omitting category returns all unit types.
        -- No params object needed (unlike CRS info list).
}

rule GetCelestialBodyList {
    -- Return celestial body information from the database.
    -- Uses the struct-aware return type system (StructAwareReturnType invariant).
    when: GetCelestialBodyList(context?, auth_name?)

    ensures: result != null

    @guidance
        -- @test CLJ[x] JS[x] PW[x] Java[x]
        -- -> non-empty list containing "Earth"
        --
        -- Returns all celestial bodies known to PROJ (Earth, Moon, Mars, etc.).
        -- No params object needed (unlike CRS info list).
}

-- Object Inspection Flow

rule GetName {
    when: GetName(obj)
    requires: obj != null
    ensures: result != null

    @guidance
        -- @test CLJ[x] JS[x] PW[x] Java[ ]
        -- EPSG:4326 -> "WGS 84"
}

rule AsWkt {
    -- Serialize a PROJ object to WKT.
    -- See AsProjString for exportability limitations on concatenated operations.
    when: AsWkt(pj, context?, type?, options?)
    requires: pj != null
    ensures:
        if pj.type in {concatenated_operation}:
            result = null -- PROJ C limitation: not exportable
        else:
            result != null

    @guidance
        -- @test CLJ[x] JS[x] PW[x] Java[x]
        -- EPSG:4326 -> WKT string containing "WGS 84"
        -- 4326->2249 CRS-to-CRS PJ -> null (concatenated operation, not exportable)
}

rule AsProjJson {
    -- Serialize a PROJ object to PROJJSON.
    -- See AsProjString for exportability limitations on concatenated operations.
    when: AsProjJson(pj, context?, options?)
    requires: pj != null
    ensures:
        if pj.type in {concatenated_operation}:
            result = null -- PROJ C limitation: not exportable
        else:
            result != null

    @guidance
        -- @test CLJ[x] JS[x] PW[x] Java[x]
        -- EPSG:4326 -> JSON string containing "GeographicCRS"
        -- 4326->2249 CRS-to-CRS PJ -> null (concatenated operation, not exportable)
}

rule AsProjString {
    -- Serialize a PROJ object to a PROJ string.
    -- Not all PROJ object types are exportable. CRS-to-CRS transformations
    -- (from projCreateCrsToCrs) that produce concatenated operations internally
    -- cannot be exported -- PROJ C returns NULL / "". Same limitation applies
    -- to AsProjjson and AsWkt on these objects.
    -- To get a PROJ string for a projected CRS's map projection, extract the
    -- conversion via: projGetTargetCrs -> projCrsGetCoordoperation ->
    -- AsProjString on the coordoperation.
    when: AsProjString(pj, context?, type?, options?)
    requires: pj != null
    ensures:
        if pj.type in {concatenated_operation}:
            result in {null, ""} -- PROJ C limitation: not exportable
            -- JVM: nil (PROJ returns NULL, dispatch converts to nil)
            -- JS: "" (worker returns empty string)
        else:
            result != null

    @guidance
        -- @test CLJ[x] JS[x] PW[x] Java[x]
        -- 4326->3857 transformation -> string containing "proj"
        -- 4326->2249 CRS-to-CRS PJ -> nil/"" (concatenated operation, not exportable)
        -- EPSG:2249 coordoperation -> string containing "+proj=lcc"
}

